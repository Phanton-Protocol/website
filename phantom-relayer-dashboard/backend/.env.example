# Phantom relayer backend — copy to `.env` (never commit real secrets)

# --- Environment tier (relayer) ---
# Local/dev: leave PHANTOM_DEPLOYMENT_TIER unset or empty; DEV_BYPASS_* may be used for local proving.
# Staging/production: set PHANTOM_DEPLOYMENT_TIER=staging or production — DEV_BYPASS_VALIDATORS / DEV_BYPASS_PROOFS
# are blocked unless PHANTOM_EMERGENCY_BYPASS_DEV_FLAGS=true (documented incident response only; rotate off immediately).
# NODE_ENV=production still enforces additional checks (CORS, keys, SEE, etc.); tier gates bypass flags independently.
PHANTOM_DEPLOYMENT_TIER=
# PHANTOM_EMERGENCY_BYPASS_DEV_FLAGS=true   # emergency only — never on a public production host

NODE_ENV=development
PORT=5050
# If `npm run dev` prints "Port 5050 in use, trying 5051", point clients at the real port:
#   export API_URL=http://127.0.0.1:5051
# `npm run mvp:preflight` and E2E scripts scan 5050–5060 when API_URL is unset or wrong.

CHAIN_ID=97
RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

SHIELDED_POOL_ADDRESS=
SWAP_ADAPTOR_ADDRESS=
OFFCHAIN_ORACLE_ADDRESS=
RELAYER_STAKING_ADDRESS=
NOTE_STORAGE_ADDRESS=

RELAYER_PRIVATE_KEY=

RELAYER_DRY_RUN=false
# Dev-only shortcuts (disallowed for PHANTOM_DEPLOYMENT_TIER=staging|production unless emergency flag above)
DEV_BYPASS_VALIDATORS=true
DEV_BYPASS_PROOFS=false

# For real Pancake quotes + on-chain swap on BSC testnet use dex (not mock):
QUOTE_MODE=dex
CORS_ORIGINS=http://localhost:5173

SEE_MODE=disabled

# --- Module 7 (staging / production hygiene) ---
# When PHANTOM_DEPLOYMENT_TIER is `staging` or `production`, startup fails if ShieldedPool.verifier() or
# swapAdaptor() bytecode matches MockVerifier / MockSwapAdaptor (see config/module7-mock-bytecode-hashes.json).
# PHANTOM_SKIP_NO_MOCK_GATE=true   # emergency only — do not use on real prod

# DEX swap fee in bps — must match M3 on-chain policy (default 10 = 0.1%)
# PHANTOM_DEX_SWAP_FEE_BPS=10

# Module 4 deposit API (if enforced)
MODULE4_DEPOSIT_API_SECRET=

# Relayer EOA must be registered on-chain: RelayerRegistry.isRelayer(relayer)==true
# or /relayer/deposit/submit returns 503. Run: npm run mvp:preflight

# Optional Chainalysis (Module 6) — same screening HTTP API for deposit/shadow-address, withdraw (recipient), and swap (intent user)
CHAINALYSIS_ENABLED=false
CHAINALYSIS_API_KEY=
CHAINALYSIS_API_URL=

# Module 3 encrypted notes
# NOTES_ENCRYPTION_KEY_HEX=

# --- Groth16 join/split (must match on-chain JoinSplitVerifier.sol) ---
# Default: backend auto-uses `Phantom-Smart-Contracts/circuits/joinsplit_public9/` (same zkey as committed verifier).
# Override only if you know wasm+zkey are a matched pair:
# PROVER_WASM=
# PROVER_ZKEY=
# If backend is not under `core/phantom-relayer-dashboard/`, set repo core root:
# PHANTOM_CORE_ROOT=/absolute/path/to/core

# --- Module 7 scripted E2E (deposit → swap → withdraw) ---
# Use a USER wallet key for signing intents (not the relayer key). Relayer pays Module4 BNB relay deposits.
# API_URL=http://127.0.0.1:5050
# E2E_USER_PRIVATE_KEY=
# E2E_MODE=bnb
# Optional: require wallet to match a funded address
# E2E_EXPECT_USER_ADDRESS=0x00b684Ca54D3174a13b28B9d08BcbbE18101e9A9
# BNB note size must be ≤ GET /config → module4RelayerDeposit.maxBnbWei (default 5e16 wei)
# E2E_DEPOSIT_WEI=45000000000000000
# Leave headroom on the change note after swap so withdraw can split payout + fees:
# E2E_RESERVE_CHANGE_AFTER_SWAP_WEI=12000000000000000
# E2E_MAX_SWAP_GAS_REFUND_WEI=2500000000000000
# Join-split public-input protocol fee (usually 0). Do NOT set from /quote fees.totalFee.
# E2E_JOIN_SPLIT_PROTOCOL_FEE_WEI=0
# Smaller withdraw leg (defaults in script) fit under ~0.012 tBNB change:
# E2E_WITHDRAW_PAYOUT_WEI=2500000000000000
# E2E_PROTOCOL_FEE_WEI=800000000000000
# E2E_GAS_REFUND_WEI=400000000000000
