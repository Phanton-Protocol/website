{
  "name": "phantom-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:site": "vite --host 0.0.0.0 --port 5173",
    "dev:local": "powershell -ExecutionPolicy Bypass -File ./run-local-stack.ps1",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:backend": "npm run test --prefix phantom-relayer-dashboard/backend",
