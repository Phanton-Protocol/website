# =============================================================================
# Copy this file to `.env` in THIS directory:  core/.env
# Hardhat loads it from:  core/Phantom-Smart-Contracts/hardhat.config.cjs
# NEVER commit `.env` — it is gitignored.
# =============================================================================

# --- Deployer wallet (BSC Testnet / Mainnet deploys) ---
# Hex private key, with or without 0x. Only ONE of these is needed.
# DEPLOYER_PRIVATE_KEY is preferred if both are set.
DEPLOYER_PRIVATE_KEY=

# Alternative name (used if DEPLOYER_PRIVATE_KEY is empty)
PRIVATE_KEY=

# --- RPC URLs (optional — defaults come from Phantom-Smart-Contracts/config/*.json) ---
# BSC Testnet (chain id 97)
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545

# BSC Mainnet (chain id 56) — only if you deploy to mainnet
# BSC_MAINNET_RPC=https://bsc-dataseed.binance.org

# --- Optional: force full contract tree for one-off shell commands ---
# HH_FULL=1

# --- Deploy profile (Module 1 / Module 7) — default dev uses MockVerifier + MockSwapAdaptor ---
# DEPLOY_PROFILE=dev
# For staging/production (real Groth16 + Pancake adaptor), set:
# DEPLOY_PROFILE=staging
# PANCAKE_ROUTER=0x...   # Pancake V2 router on target network
# WBNB_ADDRESS=0x...     # WBNB (or wrapped native) on target network
# Optional: reuse an already deployed Groth16 verifier contract
# JOIN_SPLIT_GROTH16_ADDRESS=0x...
#
# Module 7: never force mocks on staging/production deploys:
# FORCE_MOCK_INFRASTRUCTURE=true   # forbidden when DEPLOY_PROFILE=staging|production (deploy will throw)
#
# After changing mock contracts / compiler, refresh fingerprints used by scripts + relayer gate:
#   node Phantom-Smart-Contracts/scripts/compute-mock-bytecode-hashes.cjs
#
# On-chain mock check (example):
#   cd Phantom-Smart-Contracts && SHIELDED_POOL_ADDRESS=0x... npm run assert:no-mock-pool -- --network bscTestnet

# --- seed-assets.ts (optional post-deploy) ---
# BNB_USD_FEED=0x...
# ASSET_1_ADDRESS=0x...  ASSET_1_USD_FEED=0x...
# ASSET_2_ADDRESS=0x...  ASSET_2_USD_FEED=0x...
