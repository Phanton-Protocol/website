# =============================================================================
# Copy this file to `.env` in THIS directory:  core/.env
# Hardhat loads it from:  core/Phantom-Smart-Contracts/hardhat.config.cjs
# NEVER commit `.env` — it is gitignored.
# =============================================================================

# --- Deployer wallet (BSC Testnet / Mainnet deploys) ---
# Hex private key, with or without 0x. Only ONE of these is needed.
# DEPLOYER_PRIVATE_KEY is preferred if both are set.
DEPLOYER_PRIVATE_KEY=

# Alternative name (used if DEPLOYER_PRIVATE_KEY is empty)
PRIVATE_KEY=

# --- RPC URLs (optional — defaults come from Phantom-Smart-Contracts/config/*.json) ---
# BSC Testnet (chain id 97)
BSC_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545

# BSC Mainnet (chain id 56) — only if you deploy to mainnet
# BSC_MAINNET_RPC=https://bsc-dataseed.binance.org

# --- Optional: force full contract tree for one-off shell commands ---
# HH_FULL=1
