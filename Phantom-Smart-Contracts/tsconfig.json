{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "types": ["node"]
  },
  "include": ["hardhat.config.cjs", "scripts/**/*.ts", "test/**/*.ts", "typechain-types/**/*.ts"]
}
