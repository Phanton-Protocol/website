{
  "name": "phantom-smart-contracts",
  "private": true,
  "version": "0.0.0",
  "description": "Hardhat project: Phantom protocol Solidity contracts, tests, and deploy scripts",
  "scripts": {
    "compile": "hardhat compile",
    "compile:full": "HH_FULL=1 hardhat compile",
    "test": "HH_FULL=1 hardhat test",
    "test:contracts": "HH_FULL=1 hardhat test",
    "deploy:testnet": "HH_FULL=1 hardhat run scripts/deploy/deploy-core.ts --network bscTestnet",
    "deploy:handlers": "HH_FULL=1 hardhat run scripts/deploy/deploy-handlers.ts --network bscTestnet",
    "deploy:core:local": "HH_FULL=1 hardhat run scripts/deploy/deploy-core.ts --network hardhat",
    "deploy:all:local": "HH_FULL=1 hardhat run scripts/deploy/deploy-all.ts --network hardhat",
    "assert:no-mock-pool": "HH_FULL=1 hardhat run scripts/assert-no-mock-pool.ts",
    "fingerprints:mock-bytecode": "node scripts/compute-mock-bytecode-hashes.cjs",
    "circuit:build:joinsplit": "bash scripts/circuits/build-joinsplit-public9.sh"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6",
    "@openzeppelin/contracts-upgradeable": "^4.9.6",
    "dotenv": "^17.4.1",
    "ethers": "^6.15.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/node": "^25.6.0",
    "hardhat": "^2.28.0",
    "snarkjs": "^0.7.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node",
      "esModuleInterop": true
    }
  }
}
